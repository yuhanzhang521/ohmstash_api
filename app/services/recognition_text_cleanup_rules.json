{
  "sentence_delimiters": "。；;，,",
  "trim_characters": "。；;，, \n\t",
  "verification_warning_prefixes": [
    "未检索到",
    "未找到",
    "没有可确认",
    "无法确认",
    "搜索结果不足"
  ],
  "verification_warning_phrases": [
    "(?:暂)?保留原标注"
  ],
  "verification_note_prefix_patterns": [
    "(?:联网)?搜索摘要确认[:：]?\\s*",
    "联网确认[:：]?\\s*"
  ],
  "model_correction_trigger": "搜索结果",
  "model_correction_target_prefix": "搜索结果指向",
  "model_correction_main_prefix": "搜索结果主要指向",
  "model_correction_pattern": "搜索结果指向\\s*(?P<target>[^：:。；;，,\\n]+)(?:[：:]\\s*(?P<summary>[^。；;\\n]+))?[。；;，,\\s]*(?P<warning>原始[^。；;\\n]*(?:疑似|可能)[^。；;\\n]*)",
  "model_multi_correction_pattern": "搜索结果(?:主要)?指向\\s*(?P<targets>[^。；;\\n]+?)(?:等(?:其他)?型号)?[，,\\s]*(?P<warning>原始[^。；;\\n]*(?:疑似|可能|误差|抄写|识别)[^。；;\\n]*)",
  "model_correction_target_pattern": "搜索结果(?:主要)?指向\\s*(?P<target>[^：:。；;，,\\n]+)",
  "model_token_pattern": "[A-Za-z][A-Za-z0-9._/-]*\\d[A-Za-z0-9._/-]*",
  "attribute_uncertainty_patterns": [
    "[（(][^（）()]{0,30}(?:未能|不能|无法|不足|不确定|待确认|不同厂商|版本不一致)[^（）()]{0,40}[）)]",
    "(?:未能|不能|无法|不足|不确定|待确认|不同厂商|版本不一致)[^。；;，,\\n]*"
  ],
