# .env.example
DATABASE_URL=postgresql://user:password@host:port/dbname
PROJECT_NAME="OhmStash API"
API_V1_STR="/api/v1"
LOG_LEVEL=INFO
LOG_FILE_PATH=
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=password
SERVER_HOST=0.0.0.0
HTTP_PORT=8000
HTTPS_ENABLED=true
HTTPS_PORT=8443
HTTPS_CERTIFICATE_SOURCE=self-signed
SSL_CERTFILE=
SSL_KEYFILE=
ACME_CHALLENGE_TYPE=http-01
ACME_DOMAIN=
ACME_EMAIL=
ACME_CLOUDFLARE_API_TOKEN=
CADDY_CONFIG_PATH=caddy/Caddyfile
CADDY_BACKEND_HOST=127.0.0.1
